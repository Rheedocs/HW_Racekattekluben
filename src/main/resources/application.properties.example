spring.application.name=HW_RaceKatteKlubben

spring.datasource.url=jdbc:mysql://localhost:3306/racekatteklubben?createDatabaseIfNotExist=true
spring.datasource.username=
spring.datasource.password=
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# Sæt til true når projektet er klar til produktion
spring.thymeleaf.cache=false

# Sæt til never efter første kørsel
spring.sql.init.mode=always

server.port=8080